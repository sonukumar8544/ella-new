{% liquid
    assign url = shop.url
    assign page_type = request.page_type
%}
{%- if page_type == 'product' -%}
    {%- liquid
        assign fa_current_variant = product.selected_or_first_available_variant
        assign fa_variant_count = product.variants | size
        assign fa_count = 0
    -%}
  
{% assign original_price1 = product.metafields.custom.price_schema.value %}

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": "{{ product.title | strip_html | escape }}",
  "url": "{{ shop.url }}{{ product.url }}",
  {%- if product.variants.first.barcode.size == 12 -%}
    "gtin12": {{ product.variants.first.barcode }},
  {%- endif -%}
  {%- if product.variants.first.barcode.size == 13 -%}
    "gtin13": {{ product.variants.first.barcode }},
  {%- endif -%}
  {%- if product.variants.first.barcode.size == 14 -%}
    "gtin14": {{ product.variants.first.barcode }},
  {%- endif -%}
  "productID": "{{ product.id }}",
  "brand": {
    "@type": "Thing",
    "name": "{{ product.vendor | escape }}"
  },
  "description": "{{ product.description | strip_html  }}",
  "image": "https:{{ product.featured_image.src | img_url: 'master' }}",
  "offers": {
    "@type": "Offer",
    "priceCurrency": "{{ shop.currency }}",
    "price": "{% for price in original_price1 %}
  {% if localization.country.currency.iso_code == 'USD' and forloop.index0 == 0 %}
    {{ price }}
  {% elsif localization.country.currency.iso_code == 'CAD' and forloop.index0 == 1 %}
    {{ price }}
  {% endif %}
{% endfor %}",
    "priceValidUntil": "2025-12-31",
    "availability": "{% if product.available %}http://schema.org/InStock{% else %}http://schema.org/OutOfStock{% endif %}",
    "url": "{{ shop.url }}{{ product.url }}",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": {
      "@type": "Organization",
      "name": "{{ shop.name }}"
    }
  }
  {% if product.metafields.reviews.rating.value != blank %},
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{ 4.8 }}",
    "ratingCount": "{{ product.metafields.reviews.rating_count.value }}"
  },
   "review": [
    {
  "datePublished": "2025-06-01",
  "reviewRating": {
    "@type": "Rating",
    "author": {
      "@type": "Person"
    },
    "ratingValue": "5",
    "bestRating": "5"
  }
}

  ]
  {% endif %}
}
</script>
  
    <script type="application/ld+json">
    {
        "@context": "http://schema.org/",
        "@type": "BreadcrumbList",
        "itemListElement": [{
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ url }}"
        },
        {%- if collection -%}
            {
                "@type": "ListItem",
                "position": 2,
                "name": "{{ collection.title }}",
                "item": "{{ url }}/{{ collection.handle }}"
            },
            {
                "@type": "ListItem",
                "position": 3,
                "name": "{{ product.title }}",
                "item": "{{ canonical_url }}"
            }
        {%- else -%}
            {
                "@type": "ListItem",
                "position": 2,
                "name": "{{ product.title }}",
                "item": "{{ canonical_url }}"
            }
        {%- endif -%}]
    }
    </script>

    {%- liquid
      assign faq_metafield = product.metafields.custom.we_product_page_faqs.value
      assign faq_valid_count = 0
      if faq_metafield != blank
        for block in faq_metafield
          assign faq_parts = block | split: '|'
          assign faq_q = faq_parts[0] | default: '' | strip | strip_html
          assign faq_a = faq_parts[1] | default: '' | strip | strip_html
          if faq_q != blank and faq_a != blank
            assign faq_valid_count = faq_valid_count | plus: 1
          endif
        endfor
      endif
    -%}
    {%- if faq_valid_count > 0 -%}
      {%- liquid
        assign faq_script_close = '</scr' | append: 'ipt>'
        assign faq_script_close_esc = '<\/scr' | append: 'ipt>'
      -%}
      {%- capture faq_ld_json -%}
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "url": {{ canonical_url | json }},
        "mainEntity": [
          {%- assign faq_needs_comma = false -%}
          {%- for block in faq_metafield -%}
            {%- assign faq_parts = block | split: '|' -%}
            {%- assign faq_q = faq_parts[0] | default: '' | strip | strip_html -%}
            {%- assign faq_a = faq_parts[1] | default: '' | strip | strip_html -%}
            {%- if faq_q != blank and faq_a != blank -%}
              {%- if faq_needs_comma -%},{%- endif -%}
              {
                "@type": "Question",
                "name": {{ faq_q | json }},
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": {{ faq_a | json }}
                }
              }
              {%- assign faq_needs_comma = true -%}
            {%- endif -%}
          {%- endfor -%}
        ]
      }
      {%- endcapture -%}
      <script type="application/ld+json">{{ faq_ld_json | strip | replace: faq_script_close, faq_script_close_esc }}</script>
    {%- endif -%}
{%- elsif page_type == 'article' -%}
    <script type="application/ld+json">
        {{ article | structured_data }}
    </script>
    <script type="application/ld+json">
    {
        "@context": "http://schema.org/",
        "@type": "BreadcrumbList",
        "itemListElement": [{
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ url }}"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "{{ article.title }}",
            "item": "{{ canonical_url }}"
        }]
    }
    </script>
{%- elsif page_type == 'collection' and collection.handle -%}
    <script type="application/ld+json">
    {
        "@context": "http://schema.org/",
        "@type": "CollectionPage",
        "name": "{{ collection.title }}",
        "url": "{{ canonical_url }}",
        "description": "{{ collection.description | split: '[lang2]' | first | strip_html }}"
    }
    </script>
    <script type="application/ld+json">
    {
        "@context": "http://schema.org/",
        "@type": "BreadcrumbList",
        "itemListElement": [{
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ url }}"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "{{ collection.title }}",
            "item": "{{ canonical_url }}"
        }]
    }
    </script>
{%- endif -%}