{% liquid
    assign url = shop.url
    assign page_type = request.page_type
%}
{%- if page_type == 'product' -%}
    {%- liquid
        assign fa_current_variant = product.selected_or_first_available_variant
        assign fa_variant_count = product.variants | size
        assign fa_count = 0
    -%}
  
{% assign original_price1 = product.metafields.custom.price_schema.value %}

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": "{{ product.title | strip_html | escape }}",
  "url": "{{ shop.url }}{{ product.url }}",
  {%- liquid
    assign fa_barcode = fa_current_variant.barcode | default: '' | strip
  -%}
  {%- if fa_barcode.size == 12 -%}
    "gtin12": {{ fa_barcode | json }},
  {%- endif -%}
  {%- if fa_barcode.size == 13 -%}
    "gtin13": {{ fa_barcode | json }},
  {%- endif -%}
  {%- if fa_barcode.size == 14 -%}
    "gtin14": {{ fa_barcode | json }},
  {%- endif -%}
  "productID": "{{ product.id }}",
  "brand": {
    "@type": "Thing",
    "name": "{{ product.vendor | escape }}"
  },
  "description": "{{ product.description | strip_html  }}",
  "image": "https:{{ product.featured_image.src | img_url: 'master' }}",
  "offers": {
    "@type": "Offer",
    "priceCurrency": "{{ shop.currency }}",
    "price": "{% for price in original_price1 %}
  {% if localization.country.currency.iso_code == 'USD' and forloop.index0 == 0 %}
    {{ price }}
  {% elsif localization.country.currency.iso_code == 'CAD' and forloop.index0 == 1 %}
    {{ price }}
  {% endif %}
{% endfor %}",
    "priceValidUntil": "2025-12-31",
    "availability": "{% if product.available %}http://schema.org/InStock{% else %}http://schema.org/OutOfStock{% endif %}",
    "url": "{{ shop.url }}{{ product.url }}",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": {
      "@type": "Organization",
      "name": "{{ shop.name }}"
    }
  }
  {% if product.metafields.reviews.rating.value != blank %},
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{ 4.8 }}",
    "ratingCount": "{{ product.metafields.reviews.rating_count.value }}"
  },
   "review": [
    {
  "datePublished": "2025-06-01",
  "reviewRating": {
    "@type": "Rating",
    "author": {
      "@type": "Person"
    },
    "ratingValue": "5",
    "bestRating": "5"
  }
}

  ]
  {% endif %}
}
</script>


{%- liquid
  # we_product_page_faqs: list.*, json array, or text. Looping a plain string iterates characters (zero valid Q|A).
  assign faq_mf = product.metafields.custom.we_product_page_faqs
  if faq_mf != blank
    if faq_mf.list?
      assign faq_iter = faq_mf.value
    elsif faq_mf.type == 'json' and faq_mf.value != blank
      assign faq_iter = faq_mf.value
    elsif faq_mf.type == 'multi_line_text_field' or faq_mf.type == 'single_line_text_field'
      assign faq_blob = faq_mf.value | default: '' | strip | newline_to_br | split: '<br />'
      assign faq_iter = faq_blob
    elsif faq_mf.value != blank and faq_mf.type != 'rich_text_field'
      assign faq_blob = faq_mf.value | strip | newline_to_br | split: '<br />'
      assign faq_iter = faq_blob
    endif
  endif
-%}
{%- capture faq_ldjson_main_entity -%}
  {%- assign faq_schema_first = true -%}
  {%- if faq_iter != blank -%}
    {%- for block in faq_iter -%}
      {%- assign row = block | strip -%}
      {%- if row != blank and row contains '|' -%}
        {%- assign parts = row | split: '|' -%}
        {%- assign question_text = parts[0] | default: '' | strip | strip_html -%}
        {%- assign answer_text = '' -%}
        {%- for part in parts offset: 1 -%}
          {%- if forloop.first -%}
            {%- assign answer_text = part -%}
          {%- else -%}
            {%- assign answer_text = answer_text | append: '|' | append: part -%}
          {%- endif -%}
        {%- endfor -%}
        {%- assign answer_text = answer_text | strip | strip_html -%}
        {%- if question_text != blank and answer_text != blank -%}
          {%- unless faq_schema_first -%},{%- endunless -%}
          {
            "@type": "Question",
            "name": {{ question_text | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ answer_text | json }}
            }
          }
          {%- assign faq_schema_first = false -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endcapture -%}
{%- assign faq_ldjson_main_entity = faq_ldjson_main_entity | strip -%}
{% if faq_ldjson_main_entity != blank %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "about": {
        "@type": "Product",
        "name": {{ product.title | strip_html | json }},
        "url": {{ shop.url | append: product.url | json }}
      },
      "mainEntity": [
        {{ faq_ldjson_main_entity }}
      ]
    }
  </script>
{% endif %}


  
    <script type="application/ld+json">
    {
        "@context": "http://schema.org/",
        "@type": "BreadcrumbList",
        "itemListElement": [{
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ url }}"
        },
        {%- if collection -%}
            {
                "@type": "ListItem",
                "position": 2,
                "name": "{{ collection.title }}",
                "item": "{{ url }}/{{ collection.handle }}"
            },
            {
                "@type": "ListItem",
                "position": 3,
                "name": "{{ product.title }}",
                "item": "{{ canonical_url }}"
            }
        {%- else -%}
            {
                "@type": "ListItem",
                "position": 2,
                "name": "{{ product.title }}",
                "item": "{{ canonical_url }}"
            }
        {%- endif -%}]
    }
    </script>
{%- elsif page_type == 'article' -%}
    <script type="application/ld+json">
        {{ article | structured_data }}
    </script>
    {%- liquid
        assign article_read_time_mf = article.metafields.custom.article_faqs_schema
        assign article_read_time = ''
        if article_read_time_mf != blank
          if article_read_time_mf.type == 'rich_text_field'
            assign article_read_time = article_read_time_mf | metafield_text
          else
            assign article_read_time = article_read_time_mf.value | default: article_read_time_mf
          endif
        endif
        assign article_read_time = article_read_time | default: '' | append: '' | strip
      -%}
    <script type="application/ld+json">
    {
        "@context": "http://schema.org/",
        "@type": "BreadcrumbList",
        "itemListElement": [{
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ url }}"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "{{ article.title }}",
            "item": "{{ canonical_url }}"
        }]
    }
    </script>
{%- elsif page_type == 'collection' and collection.handle -%}
    <script type="application/ld+json">
    {
        "@context": "http://schema.org/",
        "@type": "CollectionPage",
        "name": "{{ collection.title }}",
        "url": "{{ canonical_url }}",
        "description": "{{ collection.description | split: '[lang2]' | first | strip_html }}"
    }
    </script>
    <script type="application/ld+json">
    {
        "@context": "http://schema.org/",
        "@type": "BreadcrumbList",
        "itemListElement": [{
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ url }}"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "{{ collection.title }}",
            "item": "{{ canonical_url }}"
        }]
    }
    </script>
{%- endif -%}