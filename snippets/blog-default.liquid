 {% comment %} {%- endif -%}  {% endcomment %}

  <div class="five-latest-blog"></div>
  <div id="blog-page-card-wrapper-banner" class="page-content main-blog {% if settings.banner_animation == 'effect_fade_up' %} scroll-trigger animate--slide-in{% endif %}">
  <div id="blog-page-card-wrapper" class="blog-row blog-block-item column-1">
        {% paginate blog.articles by 12 %}
          {%- for article in blog.articles -%}
            {%- assign matches_category = false -%}
            {%- for tag in article.tags -%}
              {%- assign tag_norm = tag | handleize | replace: '-', '' | replace: '_', '' | downcase -%}
              {%- if tag_norm == active_tag_norm -%}
                {%- assign matches_category = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if matches_category -%}
                <div class="item{% if forloop.first == true %} item--first{% endif %}{% if settings.banner_animation == 'effect_fade_up' %} scroll-trigger animate--slide-in{% endif %}" 
                   style="{% if settings.banner_animation == 'effect_fade_up' %}--animation-order: {{ forloop.index }};{% endif %}--color-summary-style: {{ text_color }}"
                   >
                {% render 'article-card-3',
                  article: article,
                  media_size: media_size,
                  portrait_aspect_ratio: portrait_aspect_ratio,
                  blog_text_align: blog_text_align,
                  show_author: show_author,
                  show_date: show_date,
                  show_summary: show_summary,
                  show_read_more: show_read_more,
                  show_comment: show_comment,
                  show_placeholder: show_placeholder,
                  first: first,
                  catewords: 30
                %}
              </div>
            {%- endif -%}
          {%- endfor -%}
          
          {%- if paginate.pages > 1 -%}
            <div class="pagination" role="navigation" aria-label="Pagination">
              {%- if paginate.previous -%}
                <a class="pagination__arrow prev" href="{{ paginate.previous.url }}">← Previous</a>
              {%- else -%}
                <span class="pagination__arrow prev" aria-disabled="true">← Previous</span>
              {%- endif -%}
              
              <div class="pagination__numbers">
                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <a href="{{ part.url }}">{{ part.title }}</a>
                  {%- else -%}
                    {%- if part.title == paginate.current_page -%}
                      <span class="active">{{ part.title }}</span>
                    {%- else -%}
                      <span class="ellipsis">{{ part.title }}</span>
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
              
              {%- if paginate.next -%}
                <a class="pagination__arrow next" href="{{ paginate.next.url }}">Next →</a>
              {%- else -%}
                <span class="pagination__arrow next" aria-disabled="true">Next →</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        {% endpaginate %}
      </div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    // Show sidebar when clicking on .filter-blog-popups
    const filterBlogPopups = document.querySelector(".filter-blog-popups");
    if (filterBlogPopups) {
      filterBlogPopups.addEventListener("click", function () {
        const sidebar = document.querySelector(".halo-blog-content.halo-grid-content .page-sidebar");
        if (sidebar) {
          sidebar.style.display = "block";
        }
      });
    }

    // Hide sidebar when clicking on .blog-filter-btn-popup
    const blogFilterBtn = document.querySelector(".blog-filter-btn-popup");
    if (blogFilterBtn) {
      blogFilterBtn.addEventListener("click", function () {
        const sidebar = document.querySelector(".halo-blog-content.halo-grid-content .page-sidebar");
        if (sidebar) {
          sidebar.style.display = "none";
        }
      });
    }
  });
</script>

