<div data-section-id="{{ section.id }}" data-section-type="blog-layout-default" id="BlogSection-{{ section.id }}" data-section="{{ section.id }}" class="main-blog-block blog-layout-default">
    <div class="{% if container == '1170' %}container-1170{% elsif container == '1770' %}container-1770{% elsif container == 'fullwidth'%}container-full{% else %}container{% endif %}">
        {%- if show_breadcrumb -%}
            <div class="hide-on-desktop hide-mobile-bradecrun">
                {% render 'breadcrumb', alignment: breadcrumb_alignment %}
            </div>
        {%- endif -%}
        {%- if show_sidebar -%}
            <div id="blog-page-heading-title" class="header-with-sidebar{% if settings.banner_animation == 'effect_fade_up' %} scroll-trigger animate--slide-in{% endif %}">
        {% endif %}
            {%- if show_page_title -%}
                <h1 class="page-header text-{{ page_title_alignment }}">
                    {{ blog.title | escape }}
                </h1>
            {%- endif -%}
            {%- if show_sidebar and section.blocks.size > 0 -%}
                <div class="blog-filter-mobile-wrapper" data-sidebar>
                    <button class="filter-btn-mob">Explore Categories</button>
                </div>
            {%- endif -%}
        {% if show_sidebar %}
            </div>
        {% endif %}
        {%- if show_breadcrumb -%}
            <div class="hide-on-mobile">
                {% render 'breadcrumb', alignment: breadcrumb_alignment %}
            </div>
        {%- endif -%}
        
        {%- comment -%}
          Blog filters: Shopify /tagged/HANDLE URLs. Tags in admin use compact handles (e.g. bonehealth), not "Bone health".
          Normalization strips hyphens/underscores + downcases so bone-health, bone_health, bonehealth all match.
          "All Blogs" = posts tagged wellness.
        {%- endcomment -%}
        {%- liquid
          assign default_all_tag_norm = 'wellness'
          assign active_tag_norm = default_all_tag_norm
          if current_tags != blank
            assign active_tag_norm = current_tags.first | handleize | replace: '-', '' | replace: '_', '' | downcase
          elsif request.params.tag != blank
            assign active_tag_norm = request.params.tag | handleize | replace: '-', '' | replace: '_', '' | downcase
          elsif request.params.view != blank
            assign active_tag_norm = request.params.view | handleize | replace: '-', '' | replace: '_', '' | downcase
          endif
        -%}
