{%- liquid
  assign faqs = product.metafields.custom.we_product_page_faqs.value
  assign valid_faq_count = 0
  if faqs != blank
    for block in faqs
      assign parts = block | split: '|'
      assign fq = parts[0] | strip
      assign fa = parts[1] | default: '' | strip
      if fq != blank and fa != blank
        assign valid_faq_count = valid_faq_count | plus: 1
      endif
    endfor
  endif
-%}
{%- if valid_faq_count > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
{%- assign sep = false -%}
{%- for block in faqs -%}
  {%- assign parts = block | split: '|' -%}
  {%- assign fq = parts[0] | strip -%}
  {%- assign fa = parts[1] | default: '' | strip -%}
  {%- if fq != blank and fa != blank -%}
    {%- if sep -%},{%- endif -%}
    {
      "@type": "Question",
      "name": {{ fq | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ fa | json }}
      }
    }
    {%- assign sep = true -%}
  {%- endif -%}
{%- endfor -%}
  ]
}
</script>
{%- endif -%}
