      <p>Award Winning <br> Extraction Process</p>
    </div>
    <div class="shipping-item">
      <img src="https://cdn.shopify.com/s/files/1/0735/8172/3944/files/Group_1000004387.svg?v=1752210466" alt="Shipping">
      <p>Premium Patented <br> Ingredients</p>
    </div>
    <div class="shipping-item">
      <img src="https://cdn.shopify.com/s/files/1/0735/8172/3944/files/Frame_1618873224.svg?v=1752210466" alt="Shipping">
      <p>Expert<br> Formulated</p>
    </div>
    <div class="shipping-item">
