<script>
  $(document).ready(function () {
    $('.shipping-slider').slick({
      dots: false,
      infinite: true,
      arrows: false, // Removed arrows for all devices
      speed: 300,
      autoplay: true, // Auto-slide enabled
      autoplaySpeed: 3000, // 3 seconds between slides
      slidesToShow: 5,
      slidesToScroll: 1,
      responsive: [
        {
          breakpoint: 1200,
          settings: {
            slidesToShow: 4,
          }
        },
        {
          breakpoint: 992,
          settings: {
            slidesToShow: 2,
          }
        },
        {
          breakpoint: 768,
          settings: {
            slidesToShow: 2,
            dots: false // Hide dots on mobile
          }
        },
        {
          breakpoint: 576,
          settings: {
            slidesToShow: 2,
            dots: false // Hide dots on mobile
          }
        }
      ]
    });
  });
</script>
