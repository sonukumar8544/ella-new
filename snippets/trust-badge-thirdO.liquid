    <style>
  .container.free-shipping-container {
    background: #f4f5f5;
    border-radius: 10px;
    margin-bottom: 30px;
    padding: 20px;
    max-width: 1000vw;
  }

  .product-free-shipping-section {
    display: none; /* hide grid by default, shown only on desktop */
  }

  .shipping-slider {
    display: none; /* shown on mobile/tablet */
  }

  .shipping-item {
    display: flex !important;
    align-items: center;
    text-align: left;
    gap: 10px;
    padding: 15px;
    border-radius: 10px;
    background: #f9f9f9;
    box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
    margin: 0 10px;
  }

  .shipping-item img {
    max-width: 50px;
  }

  .shipping-item p {
    font-size: 14px;
    color: #36454F;
    margin: 0;
  }

  /* Desktop layout (grid) */
  @media (min-width: 1024px) {
    .shipping-slider {
      display: none !important;
    }

    .product-free-shipping-section {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
      max-width: 1200px;
      margin: auto;
    }
  }

  /* Show slider on tablet/mobile */
  @media (max-width: 1023px) {
    .shipping-slider {
      display: block;
    }
  }

  @media (max-width: 768px) {
    .shipping-item {
    flex-direction: column;
  }

  .shipping-item p {
    font-size: 13px;
    color: #36454F;
    margin: 0;
    text-align: center;
    line-height: 1.4;
  }
  }
</style>

