    align-items: center;
    font-size: 20px;
    margin-bottom: 15px;
  }

  .healthgoal-why-benefits-box li img {
    width: 30px;
    margin-right: 10px;
  }

  /* Box styles */
  .healthgoal-why-benefits-box.dark {
    background-color: #086b92;
    color: #ffffff;
  }

  .healthgoal-why-benefits-box.light {
    background-color: #f2f2f2;
    color: #333;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .healthgoal-why-benefits-wrapper {
