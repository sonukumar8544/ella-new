{% schema %}
  {
    "name": "product home page",
    "settings": [
      {
        "type": "header",
        "content": "Product images"
      },
      {
        "type": "image_picker",
        "id": "image_desktop",
        "label": "Desktop image",
        "info": "Use a large file (about 1600–2400px wide) so it stays sharp on retina displays."
      },
      {
        "type": "image_picker",
        "id": "image_mobile",
        "label": "Mobile image",
        "info": "Optional. Shown below 768px. If empty, the desktop image is used."
      },
      {
        "type": "text",
        "id": "image_alt",
        "label": "Image alt text",
        "default": "Grass-fed bovine colostrum powder product"
      }
    ],
    "presets": [
      {
        "name": "product home page"
      }
    ]
  }
{% endschema %}
<style>
  .vitamin-section-home-container {
    /* background: linear-gradient(to right, #ffffff, #f5f5f5); */
    background-color: #f1fafe;
  }
  .vitamin-section-home {
    display: flex;
    flex-wrap: wrap;
    padding: 65px 5%;
    align-items: center;
    gap: 30px;
    max-width: 1300px;
    margin: auto;
  }

  .product-left-section-container {
    display: flex;
    flex: 1 1 clamp(280px, 52%, 700px);
    min-width: 0;
    gap: 20px;
    flex-wrap: wrap;
    align-items: center;
  }

  .vitamin-left {
    position: relative;
    width: 100%;
    flex-shrink: 0;
    line-height: 0;
  }

  .home-feature-product__picture {
    display: block;
    width: 100%;
    margin: 0;
  }

  .home-feature-product__img {
    width: 100%;
    max-width: 100%;
    height: auto;
    display: block;
    border-radius: 10px;
    object-fit: contain;
    object-position: center;
    background-color: #ffffff;
    box-shadow: 0 12px 40px rgba(8, 107, 146, 0.1);
    image-rendering: auto;
    -ms-interpolation-mode: bicubic;
  }

  .trusted-label {
    position: absolute;
    bottom: 41px;
    left: 45px;
    color: white;
    font-size: 25px;
    line-height: 1.4;
    border-left: 4px solid white;
    font-weight: 300;
    padding-left: 15px;
    display: none;
  }

  .trusted-label strong {
    font-size: 24px;
    font-weight: bold;
  }

  .vitamin-center-section {
    display: flex;
    flex-direction: column;
    gap: 15px;
    justify-content: center;
    width: 100%;
  }

  .vitamin-center-section .card {
    background: linear-gradient(135deg, #a7d7e5 0%, #086b92 100%);
    color: white;
    padding: 18px;
    border-radius: 10px;
    font-size: 18px;
    font-weight: 400;
    line-height: 1.4;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .vitamin-center-section .card p {
    color: white;
    font-size: 24px;
    line-height: 1.3;
    font-weight: 300;
  }

  .vitamin-right-section {
    flex: 1 1 clamp(280px, 42%, 520px);
    max-width: 100%;
    min-width: 0;
  }

  .vitamin-right-section h2 {
    font-size: clamp(20px, 2.5vw, 30px);
    font-weight: 700;
    margin-bottom: 15px;
    margin-top: 0px;
    text-align: left;
    line-height: 1.25;
    color: #0a3d5c;
    transition: color 0.35s ease, transform 0.35s ease;
  }

  .vitamin-right-section h2 span {
    font-style: italic;
    font-weight: bold;
    display: block;
    margin-top: 5px;
  }

  .vitamin-right-section h2:hover {
    color: #086b92;
  }

  .vitamin-right-section p {
    font-size: clamp(15px, 1.6vw, 16px);
    color: #334155;
    margin: 10px 0;
    text-align: left;
    line-height: 1.55;
    transition: color 0.3s ease;
  }

  .vitamin-right-section strong {
    font-weight: bold;
  }

  /* Scroll-in: children start hidden until section is visible */
  .home-feature-right__reveal {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .vitamin-right-section.is-visible .home-feature-right__reveal--1 {
    transition-delay: 0.05s;
  }
  .vitamin-right-section.is-visible .home-feature-right__reveal--2 {
    transition-delay: 0.18s;
  }
  .vitamin-right-section.is-visible .home-feature-right__reveal--3 {
    transition-delay: 0.3s;
  }
  .vitamin-right-section.is-visible .home-feature-right__reveal--4 {
    transition-delay: 0.42s;
  }

  .vitamin-right-section.is-visible .home-feature-right__reveal {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .home-feature-right__reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .vitamin-right-section h2:hover {
      transform: none;
    }
  }

  .shop-btn-home {
    margin: 24px 0 28px;
    display: flex;
    width: 100%;
    justify-content: stretch;
  }

  .shop-btn-home button {
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    padding: 10px 28px;
    /* border: 2px solid #0d7a8c; */
    border-radius: 999px;
    color: #fff;
    background: linear-gradient(135deg, #0d8a9e 0%, #086b92 100%);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease,
      background 0.25s ease,
      color 0.25s ease;
    box-shadow: 0 4px 14px rgba(8, 107, 146, 0.28);
  }

  .shop-btn-home button .shop-btn-home__arrow {
    display: inline-block;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .shop-btn-home button:hover {
    background: #fff;
    color: #086b92;
    border-color: #086b92;
    box-shadow: 0 6px 20px rgba(8, 107, 146, 0.2);
    transform: translateY(-2px);
  }

  .shop-btn-home button:hover .shop-btn-home__arrow {
    transform: translateX(5px);
  }

  .shop-btn-home button:active {
    transform: translateY(0);
    box-shadow: 0 2px 10px rgba(8, 107, 146, 0.22);
  }

  .shop-btn-home button:focus {
    outline: none;
  }

  .shop-btn-home button:focus-visible {
    outline: 3px solid rgba(8, 107, 146, 0.45);
    outline-offset: 3px;
  }

  .note-box {
    background: rgba(255, 255, 255, 0.55);
    padding: 18px 20px;
    border-radius: 12px;
    font-size: 16px;
    line-height: 1.65;
    text-align: left;
    border: 1px solid rgba(8, 107, 146, 0.12);
    transition:
      border-color 0.35s ease,
      box-shadow 0.35s ease,
      transform 0.35s ease,
      background 0.35s ease;
  }

  .note-box:hover {
    border-color: rgba(8, 107, 146, 0.22);
    box-shadow: 0 8px 28px rgba(8, 107, 146, 0.1);
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.85);
  }

  .note-box blockquote {
    margin: 0;
    padding: 0;
    border: none;
    font-style: normal;
  }

  .note-box .note-box__quote {
    color: #086b92;
    font-size: clamp(15px, 1.5vw, 17px);
  }

  .note-box .note-box__attrib {
    display: block;
    margin-top: 10px;
    color: #475569;
    font-size: 14px;
  }

  .note-box strong {
    display: block;
    color: #086b92;
    margin-bottom: 5px;
    font-size: 20px;
  }

  .shop-now-button {
    max-width: 190px;
  }

  @media screen and (max-width: 1150px) {
    .vitamin-section-home {
      flex-direction: column;
      align-items: stretch;
    }

    .product-left-section-container {
      flex: 1 1 auto;
      max-width: 100%;
    }

    .vitamin-right-section {
      flex: 1 1 auto;
      max-width: 640px;
      margin-left: auto;
      margin-right: auto;
      width: 100%;
    }
  }

  @media screen and (max-width: 768px) {
    .product-left-section-container {
      flex-direction: column;
    }

    .vitamin-section-home {
      padding: 40px 5% 30px !important;
      gap: 24px;
    }

    .note-box {
      padding: 16px;
    }

    .vitamin-left {
      width: 100%;
    }

    .vitamin-center-section {
      width: 100%;
    }

    .vitamin-center-section .card {
      max-width: 100%;
    }

    .note-box:hover {
      transform: none;
    }
  }

  .note-box p {
    margin-top: 12px;
    padding-left: 0;
  }
</style>

<section id="HomeFeatureProduct-{{ section.id }}" class="vitamin-section-home-container">
  <div class="vitamin-section-home">
    <div class="product-left-section-container">
      <div class="vitamin-left">
        {% liquid
          assign img_alt = section.settings.image_alt | default: 'Grass-fed bovine colostrum powder product' | strip
          assign img_desktop = section.settings.image_desktop
          assign img_mobile = section.settings.image_mobile
          if img_desktop == blank and img_mobile != blank
            assign img_desktop = img_mobile
          elsif img_mobile == blank and img_desktop != blank
            assign img_mobile = img_desktop
          endif
          assign img_fallback_desk = 'https://cdn.shopify.com/s/files/1/0735/8172/3944/files/Frame_4_2.png?v=1775649405'
          assign img_fallback_mob = 'https://cdn.shopify.com/s/files/1/0735/8172/3944/files/Instagram_post_-_3_1.png?v=1775649404'
        %}
        {% if img_desktop != blank %}
          <picture class="home-feature-product__picture">
            <source
              media="(max-width: 768px)"
              srcset="{{ img_mobile | image_url: width: 640 }} 640w,
                {{ img_mobile | image_url: width: 960 }} 960w,
                {{ img_mobile | image_url: width: 1280 }} 1280w,
                {{ img_mobile | image_url: width: 1536 }} 1536w,
                {{ img_mobile | image_url: width: 1920 }} 1920w"
              sizes="100vw"
            >
            <img
              class="home-feature-product__img"
              src="{{ img_desktop | image_url: width: 1400 }}"
              srcset="{{ img_desktop | image_url: width: 700 }} 700w,
                {{ img_desktop | image_url: width: 1050 }} 1050w,
                {{ img_desktop | image_url: width: 1400 }} 1400w,
                {{ img_desktop | image_url: width: 2100 }} 2100w,
                {{ img_desktop | image_url: width: 2800 }} 2800w"
              sizes="(max-width: 1150px) min(100vw, 640px), min(52vw, 720px)"
              width="{{ img_desktop.width }}"
              height="{{ img_desktop.height }}"
              alt="{{ img_alt | escape }}"
              loading="lazy"
              decoding="async"
            >
          </picture>
        {% else %}
          <picture class="home-feature-product__picture">
            <source
              media="(max-width: 768px)"
              srcset="{{ img_fallback_mob }}&width=640 640w,
                {{ img_fallback_mob }}&width=960 960w,
                {{ img_fallback_mob }}&width=1280 1280w,
                {{ img_fallback_mob }}&width=1536 1536w"
              sizes="100vw"
            >
            <img
              class="home-feature-product__img"
              src="{{ img_fallback_desk }}&width=1400"
              srcset="{{ img_fallback_desk }}&width=700 700w,
                {{ img_fallback_desk }}&width=1050 1050w,
                {{ img_fallback_desk }}&width=1400 1400w,
                {{ img_fallback_desk }}&width=2100 2100w,
                {{ img_fallback_desk }}&width=2800 2800w"
              sizes="(max-width: 1150px) min(100vw, 640px), min(52vw, 720px)"
              alt="{{ img_alt | escape }}"
              loading="lazy"
              decoding="async"
            >
          </picture>
        {% endif %}
        {% comment %} <div class="trusted-label">
          Trusted by150k+<br><strong>Customers</strong>
        </div> {% endcomment %}
      </div>

      {% comment %} <div class="vitamin-center-section">
        <div class="card">
          <p>The <strong>most bioactive</strong><br>form of <strong>Vitamin E</strong> in the world.</p>
        </div>
      </div> {% endcomment %}
    </div>

    <div class="vitamin-right-section" data-home-feature-right>
      <h2 class="home-feature-right__reveal home-feature-right__reveal--1">
        100% Grass-Fed Bovine Colostrum — Clinically Backed Formulation
      </h2>
      <p class="home-feature-right__reveal home-feature-right__reveal--2">
        Support immunity, gut integrity &amp; daily resilience with concentrated bioactive nutrition from grass-fed bovine colostrum
      </p>
      <div class="shop-btn-home home-feature-right__reveal home-feature-right__reveal--3">
        <button
          type="button"
          class="quiz_bundle_prodct product-form__submit button button--primary"
          data-variant-ids="49856468877608"
          data-qtys="1"
          data-redirect="/checkout"
        >
          {{- 'SHOP NOW' -}}
          <span class="shop-btn-home__arrow" aria-hidden="true"> →</span>
        </button>
      </div>
      <div class="note-box home-feature-right__reveal home-feature-right__reveal--4">
        <blockquote class="note-box__quote">
          “My digestion feels better, I get sick less often, and I just feel more like myself again.”
        </blockquote>
        <p class="note-box__attrib">— Michael B., Entrepreneur</p>
      </div>
    </div>
  </div>
</section>

<noscript>
  <style>
    #HomeFeatureProduct-{{ section.id }} .home-feature-right__reveal {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>

<script>
  (function () {
    var root = document.getElementById('HomeFeatureProduct-{{ section.id }}');
    if (!root) return;
    var right = root.querySelector('[data-home-feature-right]');
    if (!right) return;
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      right.classList.add('is-visible');
      return;
    }
    if (!('IntersectionObserver' in window)) {
      right.classList.add('is-visible');
      return;
    }
    var io = new IntersectionObserver(
      function (entries, obs) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            right.classList.add('is-visible');
            obs.disconnect();
          }
        });
      },
      { root: null, rootMargin: '0px 0px -6% 0px', threshold: 0.1 }
    );
    io.observe(right);
  })();
</script>
