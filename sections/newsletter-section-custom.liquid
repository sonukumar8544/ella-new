{% schema %}
{
  "name": "newsletter custom",
  "settings": [
    {
      "type": "image_picker",
      "id": "newsletter_image",
      "label": "Newsletter Image"
    },
     {
      "type": "color",
      "id": "newslettertext",
      "label": "title Color",
      "default": "#374650"
    },
    {
      "type": "color",
      "id": "newslettersubtitle",
      "label": "Subtitle Color",
      "default": "#374650"
    },
    {
      "type": "color",
      "id": "newsletterbg",
      "label": "Newsletter Bg",
      "default": "#e6f0f4"
    },
    {
      "type": "color",
      "id": "newsletter_border",
      "label": "Newsletter Border",
      "default": "#fff"
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Newsletter Title",
      "default": "Get 10% off your first order"
    },
    {
      "type": "text",
      "id": "newsletter_subtitle",
      "label": "Newsletter subtitle ",
      "default": "Receive discounts, updates and more by subscribing to our email newsletter + SMS!"
    },
     {
      "type": "text",
      "id": "newsletter_subtitle1",
      "label": "Newsletter subtitle 1",
      "default": "Receive discounts, updates and more by subscribing to our email newsletter + SMS!"
    }
  ],
  "presets": [
    {
      "name": "newsletter custom"
    }
  ]
}
{% endschema %}

