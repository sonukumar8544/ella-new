<!-- influencer_section slick video/image customization --->
<!-- dymanic image and video loop in shopify like dorcoindia product page --->
<div class="container influencer_section"> 
  {% if section.settings.title != blank %}<h2 class="section-heading">{{ section.settings.title }}</h2> {% endif %}
<div class=" slider-dynamic {% if section.settings.slider_gallery == true %}dynamic-slider-enable {% endif %}"  
  data-slick='{
  "slidesToShow": {{ section.settings.slidesToShow }},
  "slidesToScroll": {{ section.settings.slidesToScroll }},
  "infinite": {{ section.settings.infinite }},
  "arrows": {{ section.settings.arrows }},
  "autoplay": {{ section.settings.autoplay }},
  "autoplaySpeed": {{ section.settings.autoplaySpeed }},
  "responsive": [{"breakpoint": 1025,
     "settings": {
		  "slidesToShow": {{ section.settings.tslidesToShow }},
		  "slidesToScroll": {{ section.settings.tslidesToScroll }},
		  "infinite": {{ section.settings.tinfinite }},
		  "arrows": {{ section.settings.tarrows }},
		  "autoplay": {{ section.settings.tautoplay }},
		  "autoplaySpeed": {{ section.settings.tautoplaySpeed }}
          }
          },
          {
          "breakpoint": 768,
          "settings": {
          "slidesToShow": {{ section.settings.mslidesToShow }},
          "slidesToScroll": {{ section.settings.mslidesToScroll }},
          "infinite": {{ section.settings.minfinite }},
          "arrows": {{ section.settings.marrows }},
          "autoplay": {{ section.settings.mautoplay }},
          "autoplaySpeed": {{ section.settings.mautoplaySpeed }},
          "dots": {{ section.settings.mdots }}
          } 
          }]
  }'>
  {% for block in section.blocks %}
    <div class="desktop-{{ section.settings.desktop-grid }} mobile-{{ section.settings.mobile-grid }}">
    {% if block.type == 'block-1' %}
      <img class="influ_img" src="{{ block.settings.influncer_img | img_url : 'master' }}" alt="" title="" width="100%" height="100%" style="width:auto;">
    {% elsif  block.type == 'block-2' %}
           <video muted  loop id="" width="100%" height="100%" class="videoclas" controls playsinline  poster="{{ block.settings.background_image | img_url:"master" }}">
       <source src="{{ block.settings.video }}" controls  type="video/mp4">
    </video>
    {% endif %}
    </div>
  {% endfor %}

</div>
</div>
<style>
    .slider-dynamic {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    }
    .influ_img{
    width: 100%;
    }
    video{
    object-fit: cover;
    }
  #influ-slick_button .slick-prev{
      left: -40px;
  }
   #influ-slick_button .slick-next{
      right: -40px;
   }
 #influ-slick_button .slick-arrow svg
  {
      fill: #000;
  }
   @media (min-width: 1025px){
    .desktop-grid_5 {
    width: 20%;
    padding: 5px 5px 0px 5px;
    }
    .desktop-grid_4 {
    width: 25%;
    padding: 5px 5px 0px 5px;
    }
   }

  @media (max-width: 1024px){
      .slider-dynamic{
      grid-template-columns: auto auto;
      }
      .mobile-grid_3 {
      width: 33.33%;padding: 5px 5px 0px 5px;
      }
      .mobile-grid_2 {
      width: 50%;padding: 5px 5px 0px 5px;
      }
  }

  @media (max-width: 768px){
      .slider-dynamic{
      grid-template-columns: auto auto;
      }
      .mobile-grid_2,
      .mobile-grid_3 {
      width: 50%;
      padding: 5px 5px 0px 5px;
      } 
    #influ-slick_button .slick-arrow{
      width: auto;
    }
    #influ-slick_button .slick-next{
     right: 0px;
  }
  #influ-slick_button .slick-next svg{
  width: 30px !important; 
</style>
{% schema %}
{
