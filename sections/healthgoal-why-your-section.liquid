{% schema %}
  {
    "name": "healthgoal why your",
    "settings": [],
    "presets": [
      {
        "name": "healthgoal why your"
      }
    ]
  }
{% endschema %}

<section class="healthgoal-why-gut-stats">
  <div class="healthgoal-why-container">
    <h2 class="healthgoal-why-title">Why Your Gut Deserves<br>More Attention</h2>
    <p class="healthgoal-why-subtext">
      Your gut does more than just digest food – it shapes how you feel every day. From bloating and fatigue to mood and immunity, it all starts here.
    </p>

    <div class="healthgoal-why-stats-grid">
      <div class="health-goad-left-section-why">
        <div class="healthgoal-why-card dark">
          <small>Up to</small>
          <h3>70%</h3>
          <p>of your immune system lives in your gut</p>
        </div>
        <div class="healthgoal-why-card gradient">
          <h3>90%</h3>
          <p>of serotonin is made in the digestive tract</p>
        </div>

      </div>


      <div class="health-goad-right-section-why">
        <div class="healthgoal-why-card dark">
          <p>Your gut houses over
            <strong>100</strong>
            trillion bacteria</p>
        </div>
        <div class="healthgoal-why-card dark">
          <p>Gut inflammation is linked to
            <strong>90+</strong>
            chronic conditions</p>
        </div>
        <div class="healthgoal-why-card gradient">
          <p>
            <strong>60%</strong>
            with gut issues report fatigue or brain fog</p>
        </div>

      </div>
    </div>
  </div>
</section>


<style>
  .healthgoal-why-gut-stats {
    padding: 60px 20px;
    text-align: center;
    background-color: #ffffff;
  }

  .healthgoal-why-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .healthgoal-why-title {
    font-size: 35px;
    color: #086b92;
    margin-bottom: 16px;
    line-height: 1.1;
  }

  .healthgoal-why-subtext {
    font-size: 18px;
    color: #65676C;
    max-width: 700px;
    margin: 0 auto 55px;
    line-height: 1.6;
  }

  .healthgoal-why-stats-grid {
    display: flex;
    gap: 20px;
  }

  .health-goad-left-section-why {
    width: 50%;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .health-goad-right-section-why {
    width: 50%;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .healthgoal-why-card {
    border-radius: 10px;
    padding: 24px 20px;
    color: #fff;
    text-align: left;
    min-height: 95px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    font-size: 16px;
  }

  .healthgoal-why-card p {
    padding: 0;
    margin: 0;
    color: white;
    font-size: 18px;
  }

  .healthgoal-why-card h3 {
    font-size: 45px;
    font-weight: bold;
    color: white;
    margin: 4px 0;
    line-height: 1.3;
  }

  .healthgoal-why-card.dark {
    background-color: #086b92;
  }

  .healthgoal-why-card.gradient {
    background: linear-gradient(135deg, #086b92 0%, #a7d7e5 100%);
    color: #fff;
  }

  .healthgoal-why-card strong {
    font-weight: bold;
    font-size: 28px;
  }

  /* Responsive typography */
  @media (max-width: 600px) {
    .healthgoal-why-title {
      font-size: 26px;
    }

    .healthgoal-why-card {
      font-size: 15px;
      padding: 20px;
    }

    .healthgoal-why-card h3 {
      font-size: 20px;
    }
  }

</style>