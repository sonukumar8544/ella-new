      </div>
      <h3>
        <span class="highlight">2K+</span><br>Lives have been transformed.</h3>
    </div>
  </div>
</section>


<style>
  .testimonial-section {
    padding: 40px 20px;
    text-align: center;
    background-color: #fff;
    display: flex;
    gap: 20px;
    justify-content: center;
  }

  .testimonial-heading {
    font-size: 32px;
    color: #004c77;
    margin-bottom: 30px;
  }

  .testimonial-slider {
    width: 70%;
    display: flex;
    gap: 20px;
  }

  /* Slick Slide Styling */
  .testimonial-img-slide img {
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 0 12px rgba(0, 0, 0, 0.1);
  }

  /* Fixed Slide */
  .testimonial-fixed-slide {
    background: #000;
    color: white;
    border-radius: 12px;
    display: flex !important;
    justify-content: center;
    align-items: center;
    padding: 20px;
  }

  .fixed-content {
    text-align: center;
  }

  .fixed-content .faces img {
    width: 32px;
    height: 32px;
    margin: 0 3px;
    border-radius: 50%;
    object-fit: cover;
  }

  .fixed-content h3 {
    margin-top: 15px;
    font-size: 18px;
    font-weight: 400;
  }

  .fixed-content .highlight {
    color: #fdd835;
    font-size: 36px;
    font-weight: bold;
  }

  /* Slick fix */
  .slick-slide {
    padding: 10px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .fixed-content .highlight {
      font-size: 28px;
    }

    .fixed-content h3 {
      font-size: 16px;
    }
  }
</style>

 <script>
        $(document).ready(function(){
        $('.testimonial-slider').slick({
          slidesToShow: 3,
          slidesToScroll: 1,
          infinite: true,
          responsive: [
            {
              breakpoint: 1024,
              settings: {
                slidesToShow: 2
              }
            },
            {
              breakpoint: 768,
              settings: {
                slidesToShow: 1
              }
            }
          ]
        });
        });
</script>  