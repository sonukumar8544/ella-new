<style>
  .testimonial-section {
    padding: 40px 20px;
    text-align: center;
    background-color: #fff;
    display: flex;
    gap: 20px;
    justify-content: center;
  }

  .testimonial-heading {
    font-size: 32px;
    color: #004c77;
    margin-bottom: 30px;
  }

  .testimonial-slider {
    width: 70%;
    display: flex;
    gap: 20px;
  }

  /* Slick Slide Styling */
  .testimonial-img-slide img {
    width: 100%;

    /*
   border-radius: 12px; 
   box-shadow: 0 0 12px rgba(0, 0, 0, 0.1);
*/
  }

  /* Fixed Slide */
  .testimonial-fixed-slide {
    padding: 20px;
    width: 24%;
  }

  .testimonial-fixed-slide img {
    width: 100%;
    height: 100%;
  }


  /* Slick fix */
  .slick-slide {
    padding: 10px;
  }
</style>

<script>
        $(document).ready(function(){
        $('.testimonial-slider').slick({
          slidesToShow: 3,
          slidesToScroll: 1,
          infinite: true,
          responsive: [
            {
              breakpoint: 1024,
              settings: {
                slidesToShow: 2
              }
            },
            {
              breakpoint: 768,
              settings: {
                slidesToShow: 1
              }
            }
          ]
        });
        });
</script>