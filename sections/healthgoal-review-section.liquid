  <div class="testimonial-fixed-slide">
    <div class="fixed-content">
      <div class="faces">
        <img src="https://cdn.shopify.com/s/files/1/0735/8172/3944/files/image_18.png?v=1751021476" alt="">
        <img src="https://cdn.shopify.com/s/files/1/0735/8172/3944/files/image_18.png?v=1751021476" alt="">
        <img src="https://cdn.shopify.com/s/files/1/0735/8172/3944/files/image_18.png?v=1751021476" alt="">
