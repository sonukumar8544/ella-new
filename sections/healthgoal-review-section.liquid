      <img src="https://cdn.shopify.com/s/files/1/0735/8172/3944/files/image_18.png?v=1751021476" alt="Review 3">
    </div>
    <!-- Review Image 3 -->
    <div class="testimonial-img-slide">
      <img src="https://wellnessextract.com/cdn/shop/files/TESTIMONIALS_2.png?v=1743570486" alt="Review 3">
    </div>
    <!-- Review Image 3 -->
    <div class="testimonial-img-slide">
