{% schema %}
{
"name": "Body fat calculator",
"settings": [],
"presets": [
{
"name": "Body fat calculator",
}
]
}
{% endschema %}

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .we-bodyfat-calculator-body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            margin: 0;
            /* background: linear-gradient(135deg, #086b92, #092733, #05455a); */
        }

        .we-bodyfat-calculator-disclaimer p {
    font-size: 10px;
}
        
        .we-bodyfat-calculator-container {
            max-width: 1200px;
            width: 100%;
            background: rgba(255, 255, 255, 0.95);
            border-radius: 20px;
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            margin: 20px;
        }
        
        .we-bodyfat-calculator-header {
            background: linear-gradient(to right, #086b92, #092733);
            color: white;
            text-align: center;
            padding: 25px 20px;
            position: relative;
        }
        
        .we-bodyfat-calculator-header h1 {
            font-size: 35px;
            margin-bottom: 10px;
            color: white;
        }
        
        .we-bodyfat-calculator-header p {
            font-size: 18px;
            opacity: 1;
            color: white;
            max-width: 500px;
            line-height: 1.6;
            margin: 0 auto;
        }
        
        .we-bodyfat-calculator-content {
            display: flex;
            flex-wrap: wrap;
            padding: 30px;
        }
        
        .we-bodyfat-calculator-calculator-container {
            flex: 1;
            min-width: 300px;
            padding: 20px;
        }
        
        .we-bodyfat-calculator-info-container {
            flex: 1;
            min-width: 300px;
            padding: 20px;
            background: #f8f9fa;
            border-radius: 15px;
        }
        
        .we-bodyfat-calculator-form-group {
            margin-bottom: 20px;
        }
        
        .we-bodyfat-calculator-form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #333;
        }
        
        .we-bodyfat-calculator-input-group {
            display: flex;
            align-items: center;
            background: white;
            border: 1px solid #ddd;
            border-radius: 10px;
            padding: 10px 15px;
            transition: all 0.3s ease;
        }
        
        .we-bodyfat-calculator-input-group:focus-within {
            border-color: #086b92;
            box-shadow: 0 0 0 3px rgba(8, 107, 146, 0.1);
        }
        
        .we-bodyfat-calculator-input-group i {
            color: #086b92;
            font-size: 1.2rem;
            margin-right: 10px;
        }
        
        .we-bodyfat-calculator-input-group input,
        .we-bodyfat-calculator-input-group select {
            flex: 1;
            border: none;
            outline: none;
            font-size: 16px;
            padding: 5px 0;
            background: transparent;
            color: #333;
        }
        
        .we-bodyfat-calculator-input-group input {
            width: 100%;
        }
        
        .we-bodyfat-calculator-btn-calculate {
            background: #086b92;
            color: white;
            border: none;
            padding: 15px 30px;
            font-size: 16px;
            font-weight: 600;
            border-radius: 10px;
            cursor: pointer;
            width: 100%;
            transition: all 0.3s ease;
            margin-top: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        }
        
        .we-bodyfat-calculator-btn-calculate:hover {
            transform: translateY(-3px);
            box-shadow: 0 7px 15px rgba(8, 107, 146, 0.4);
            background: #065a7d;
        }
        
        .we-bodyfat-calculator-result-container {
            margin-top: 30px;
            text-align: center;
            padding: 20px;
            border-radius: 15px;
            background: #e9ecef;
            display: none;
            animation: fadeIn 0.5s ease-in-out;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .we-bodyfat-calculator-result-value {
            font-size: 3.5rem;
            font-weight: 700;
            margin: 20px 0;
            color: #086b92;
        }
        
        .we-bodyfat-calculator-result-category {
            font-size: 1.5rem;
            font-weight: 600;
            color: #d35400;
            margin-bottom: 20px;
        }
        
        .we-bodyfat-calculator-result-description {
            font-size: 16px;
            line-height: 1.6;
            color: #333;
            padding: 0 15px;
        }
        
        .we-bodyfat-calculator-info-title {
            color: #086b92;
            margin-bottom: 20px;
            font-size: 1.8rem;
            text-align: center;
        }
        
        .we-bodyfat-calculator-info-box {
            background: white;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 25px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }
        
        .we-bodyfat-calculator-info-box h3 {
            color: #086b92;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .we-bodyfat-calculator-info-box ul {
            padding-left: 20px;
        }
        
        .we-bodyfat-calculator-info-box li {
            margin-bottom: 10px;
            line-height: 1.5;
        }
        
        .we-bodyfat-calculator-category-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }
        
        .we-bodyfat-calculator-category-table th,
        .we-bodyfat-calculator-category-table td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }
        
        .we-bodyfat-calculator-category-table th {
            background-color: #086b92;
            color: white;
        }
        
        .we-bodyfat-calculator-category-table tr:nth-child(even) {
            background-color: #f2f2f2;
        }
        
        @media (max-width: 768px) {
            .we-bodyfat-calculator-content {
                flex-direction: column;
            }
            
            .we-bodyfat-calculator-header h1 {
                font-size: 28px;
            }
            
            .we-bodyfat-calculator-header p {
                font-size: 16px;
            }
        }
        
        .we-bodyfat-calculator-disclaimer {
            text-align: center;
            padding: 20px;
            font-size: 0.9rem;
            color: #666;
            background: #f8f9fa;
            border-top: 1px solid #eee;
        }
    </style>
<div class="we-bodyfat-calculator-body">
    <div class="we-bodyfat-calculator-container">
        <header class="we-bodyfat-calculator-header">
            <h1><i class="fas fa-calculator"></i> Body Fat Percentage Calculator</h1>
            <p>Calculate your body fat percentage using the U.S. Navy method for accurate results.</p>
        </header>

        <div class="we-bodyfat-calculator-content">
            <div class="we-bodyfat-calculator-calculator-container">
                <div class="we-bodyfat-calculator-form-group">
                    <label for="gender-select">Gender</label>
                    <div class="we-bodyfat-calculator-input-group">
                        <i class="fas fa-venus-mars"></i>
                        <select id="gender-select">
                            <option value="male">Male</option>
                            <option value="female">Female</option>
                        </select>
                    </div>
                </div>

                <div class="we-bodyfat-calculator-form-group">
                    <label for="age">Age</label>
                    <div class="we-bodyfat-calculator-input-group">
                        <i class="fas fa-user-clock"></i>
                        <input type="number" id="age" min="18" max="100" value="30">
                    </div>
                </div>

                <div class="we-bodyfat-calculator-form-group">
                    <label for="height">Height</label>
                    <div class="we-bodyfat-calculator-input-group">
                        <i class="fas fa-ruler-vertical"></i>
                        <input type="number" id="height" placeholder="Enter height" value="175">
                        <select id="height-unit">
                            <option value="cm">cm</option>
                            <option value="in">inches</option>
                        </select>
                    </div>
                </div>

                <div class="we-bodyfat-calculator-form-group">
                    <label for="neck">Neck Circumference</label>
                    <div class="we-bodyfat-calculator-input-group">
                        <i class="fas fa-arrows-alt-h"></i>
                        <input type="number" id="neck" placeholder="Enter neck measurement" value="38">
                        <select id="neck-unit">
                            <option value="cm">cm</option>
                            <option value="in">inches</option>
                        </select>
                    </div>
                </div>

                <div class="we-bodyfat-calculator-form-group">
                    <label for="waist">Waist Circumference</label>
                    <div class="we-bodyfat-calculator-input-group">
                        <i class="fas fa-arrows-alt-h"></i>
                        <input type="number" id="waist" placeholder="Enter waist measurement" value="85">
                        <select id="waist-unit">
                            <option value="cm">cm</option>
                            <option value="in">inches</option>
                        </select>
                    </div>
                </div>

                <div class="we-bodyfat-calculator-form-group" id="hip-group" style="display: none;">
                    <label for="hip">Hip Circumference (Women)</label>
                    <div class="we-bodyfat-calculator-input-group">
                        <i class="fas fa-arrows-alt-h"></i>
                        <input type="number" id="hip" placeholder="Enter hip measurement" value="95">
                        <select id="hip-unit">
                            <option value="cm">cm</option>
                            <option value="in">inches</option>
                        </select>
                    </div>
                </div>

                <button class="we-bodyfat-calculator-btn-calculate" id="calculate-btn">
                    <i class="fas fa-calculator"></i> Calculate Body Fat
                </button>

                <div class="we-bodyfat-calculator-result-container" id="result-container">
                    <h2>Your Body Fat Percentage</h2>
                    <div class="we-bodyfat-calculator-result-value" id="result-value">0.0%</div>
                    <div class="we-bodyfat-calculator-result-category" id="result-category">Category</div>
                    <div class="we-bodyfat-calculator-result-description" id="result-description">
                        Description will appear here after calculation
                    </div>
                </div>
            </div>

            <div class="we-bodyfat-calculator-info-container">
                <h2 class="we-bodyfat-calculator-info-title"><i class="fas fa-info-circle"></i> About Body Fat
                    Percentage</h2>

                <div class="we-bodyfat-calculator-info-box">
                    <h3><i class="fas fa-calculator"></i> Calculation Method</h3>
                    <p>This calculator uses the U.S. Navy method to estimate body fat percentage based on body
                        measurements. The formulas used are:</p>
                    <p><strong>For men:</strong><br>
                        86.010 × log<sub>10</sub>(abdomen - neck) - 70.041 × log<sub>10</sub>(height) + 36.76</p>
                    <p><strong>For women:</strong><br>
                        163.205 × log<sub>10</sub>(waist + hip - neck) - 97.684 × log<sub>10</sub>(height) - 78.387</p>
                </div>

                <div class="we-bodyfat-calculator-info-box">
                    <h3><i class="fas fa-chart-bar"></i> Body Fat Categories</h3>
                    <table class="we-bodyfat-calculator-category-table">
                        <thead>
                            <tr>
                                <th>Category</th>
                                <th>Men</th>
                                <th>Women</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Essential Fat</td>
                                <td>2-5%</td>
                                <td>10-13%</td>
                            </tr>
                            <tr>
                                <td>Athletes</td>
                                <td>6-13%</td>
                                <td>14-20%</td>
                            </tr>
                            <tr>
                                <td>Fitness</td>
                                <td>14-17%</td>
                                <td>21-24%</td>
                            </tr>
                            <tr>
                                <td>Average</td>
                                <td>18-24%</td>
                                <td>25-31%</td>
                            </tr>
                            <tr>
                                <td>Obese</td>
                                <td>25%+</td>
                                <td>32%+</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="we-bodyfat-calculator-info-box">
                    <h3><i class="fas fa-lightbulb"></i> Measurement Tips</h3>
                    <ul>
                        <li><strong>Height:</strong> Measure without shoes</li>
                        <li><strong>Neck:</strong> Measure below the larynx with tape sloping downward</li>
                        <li><strong>Waist:</strong> Measure at the navel level while standing relaxed</li>
                        <li><strong>Hips (women):</strong> Measure at the widest part of the hips</li>
                        <li>Take measurements in the morning for consistency</li>
                        <li>Use a flexible measuring tape for accuracy</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="we-bodyfat-calculator-disclaimer">
            <p><strong>Disclaimer:</strong> This calculator provides an estimate of body fat percentage. For
                professional assessment, consult a healthcare provider. Results may vary based on individual factors.
            </p>
        </div>
    </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const genderSelect = document.getElementById('gender-select');
            const hipGroup = document.getElementById('hip-group');
            
            // Toggle hip measurement based on gender selection
            function toggleHipGroup() {
                hipGroup.style.display = genderSelect.value === 'female' ? 'block' : 'none';
            }
            
            // Initial toggle
            toggleHipGroup();
            
            // Add event listener for gender change
            genderSelect.addEventListener('change', toggleHipGroup);
            
            // Calculate button event listener
            document.getElementById('calculate-btn').addEventListener('click', calculateBodyFat);
            
            function calculateBodyFat() {
                // Get selected gender
                const gender = genderSelect.value;
                
                // Get input values
                const age = parseInt(document.getElementById('age').value) || 30;
                const height = parseFloat(document.getElementById('height').value) || 175;
                const heightUnit = document.getElementById('height-unit').value;
                const neck = parseFloat(document.getElementById('neck').value) || 38;
                const neckUnit = document.getElementById('neck-unit').value;
                const waist = parseFloat(document.getElementById('waist').value) || 85;
                const waistUnit = document.getElementById('waist-unit').value;
                let hip = 0;
                let hipUnit = 'cm'; // Default value
                
                if (gender === 'female') {
                    hip = parseFloat(document.getElementById('hip').value) || 95;
                    hipUnit = document.getElementById('hip-unit').value;
                }
                
                // Convert all measurements to cm
                const heightCm = heightUnit === 'in' ? height * 2.54 : height;
                const neckCm = neckUnit === 'in' ? neck * 2.54 : neck;
                const waistCm = waistUnit === 'in' ? waist * 2.54 : waist;
                const hipCm = gender === 'female' ? (hipUnit === 'in' ? hip * 2.54 : hip) : 0;
                
                // Calculate body fat using U.S. Navy method
                let bodyFatPercentage;
                
                if (gender === 'male') {
                    // Male formula: 86.010 * log10(waist - neck) - 70.041 * log10(height) + 36.76
                    bodyFatPercentage = 86.010 * Math.log10(waistCm - neckCm) -
                        70.041 * Math.log10(heightCm) + 36.76;
                } else {
                    // Female formula: 163.205 * log10(waist + hip - neck) - 97.684 * log10(height) - 78.387
                    bodyFatPercentage = 163.205 * Math.log10(waistCm + hipCm - neckCm) -
                        97.684 * Math.log10(heightCm) - 78.387;
                }
                
                // Ensure body fat is not negative or too high
                bodyFatPercentage = Math.max(2, Math.min(50, bodyFatPercentage));
                
                // Display result
                displayResult(bodyFatPercentage.toFixed(1), gender, age);
            }
            
            function displayResult(percentage, gender, age) {
                const resultValue = document.getElementById('result-value');
                const resultCategory = document.getElementById('result-category');
                const resultDescription = document.getElementById('result-description');
                const resultContainer = document.getElementById('result-container');
                
                resultValue.textContent = `${percentage}%`;
                
                // Determine category based on gender and percentage
                let category, description;
                const percentageNum = parseFloat(percentage);
                
                if (gender === 'male') {
                    if (percentageNum < 6) {
                        category = "Essential Fat";
                        description = "Very low body fat. Essential for physiological functions. Athletes may reach this level temporarily but maintaining it long-term may not be healthy.";
                    } else if (percentageNum < 14) {
                        category = "Athletic";
                        description = "Excellent condition. Typical for athletes and highly fit individuals. Shows good muscle definition and fitness level.";
                    } else if (percentageNum < 18) {
                        category = "Fitness";
                        description = "Good condition. Better than average, showing some muscle definition. This is a healthy range for most men.";
                    } else if (percentageNum < 25) {
                        category = "Average";
                        description = "Within normal range. May show slight abdominal definition. Could improve with better nutrition and exercise.";
                    } else {
                        category = "Above Average";
                        description = "Higher than recommended. Consider dietary improvements and regular exercise to reduce health risks associated with excess body fat.";
                    }
                } else {
                    if (percentageNum < 14) {
                        category = "Essential Fat";
                        description = "Very low body fat. Essential for physiological functions. Athletes may reach this level temporarily but maintaining it long-term may not be healthy.";
                    } else if (percentageNum < 21) {
                        category = "Athletic";
                        description = "Excellent condition. Typical for female athletes. Shows good muscle tone and fitness level.";
                    } else if (percentageNum < 25) {
                        category = "Fitness";
                        description = "Good condition. Better than average, showing some muscle definition. This is a healthy range for most women.";
                    } else if (percentageNum < 32) {
                        category = "Average";
                        description = "Within normal range. Common for women. Could improve with better nutrition and exercise.";
                    } else {
                        category = "Above Average";
                        description = "Higher than recommended. Consider dietary improvements and regular exercise to reduce health risks associated with excess body fat.";
                    }
                }
                
                resultCategory.textContent = category;
                resultDescription.textContent = description;
                resultContainer.style.display = 'block';
                
                // Scroll to results
                resultContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
            
            // Initialize with sample calculation
            calculateBodyFat();
        });
    </script>